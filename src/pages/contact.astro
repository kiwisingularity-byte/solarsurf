---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Solar Surf Board Repairs">
  <!-- Contact Hero -->
  <section class="contact-hero">
    <div class="container">
      <h1>Get In Touch</h1>
      <p>Drop off your board or give us a call — we'll get you back in the water fast.</p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="contact-section">
    <div class="container contact-grid">
      <!-- Contact Form -->
      <div class="contact-form-wrap">
        <h2>Send a Message</h2>
        <p class="form-sub">Tell us about your board and we'll get back to you with a quote.</p>
        <form class="contact-form" action="https://formspree.io/f/placeholder" method="POST">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required placeholder="Your name" />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required placeholder="you@example.com" />
            </div>
            <div class="form-group">
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" placeholder="021 123 456" />
            </div>
          </div>
          <div class="form-group">
            <label for="message">What needs fixing?</label>
            <textarea id="message" name="message" rows="5" required placeholder="E.g. 6'2 shortboard with a crack on the bottom rail..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
      </div>

      <!-- Contact Details -->
      <div class="contact-details">
        <div class="detail-card">
          <span class="detail-icon">📍</span>
          <h3>Find Us</h3>
          <p>Unit 8, 21 MacDonald Street<br/>Mount Maunganui 3116<br/>New Zealand</p>
          <p class="detail-note">5 minutes from Omanu Beach</p>
        </div>
        <div class="detail-card">
          <span class="detail-icon">📞</span>
          <h3>Call Us</h3>
          <p><a href="tel:+64275888082">027 5888 082</a></p>
          <p class="detail-note">Text or call — we're happy to help</p>
        </div>
        <div class="detail-card">
          <span class="detail-icon">✉️</span>
          <h3>Email Us</h3>
          <p><a href="mailto:maunganui@me.com">maunganui@me.com</a></p>
          <p class="detail-note">We usually respond within a few hours</p>
        </div>
        <div class="detail-card">
          <span class="detail-icon">🕐</span>
          <h3>Hours</h3>
          <p>Mon–Fri: 8am – 5pm<br/>Sat: 9am – 1pm<br/>Sun: Closed</p>
          <p class="detail-note">Drop-offs welcome during hours</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="map-section">
    <div class="container">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3168!2d176.1625!3d-37.6487!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s21+MacDonald+St+Mount+Maunganui!5e0!3m2!1sen!2snz!4v1"
        width="100%"
        height="400"
        style="border:0; border-radius: 16px;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Solar Surf Board Repairs location on Google Maps">
      </iframe>
    </div>
  </section>
</Layout>

<style>
  /* Contact Hero */
  .contact-hero {
    background: linear-gradient(135deg, #0c4a6e 0%, #0284c7 100%);
    color: white;
    padding: 80px 0 60px;
    text-align: center;
  }

  .contact-hero h1 {
    font-size: 2.8rem;
    font-weight: 800;
    margin-bottom: 12px;
  }

  .contact-hero p {
    font-size: 1.1rem;
    opacity: 0.9;
  }

  @media (max-width: 768px) {
    .contact-hero { padding: 60px 0 40px; }
    .contact-hero h1 { font-size: 2rem; }
  }

  /* Contact Grid */
  .contact-section {
    padding: 64px 0;
    background: var(--white);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 48px;
  }

  /* Form */
  .contact-form-wrap h2 {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 8px;
    color: var(--gray-900);
  }

  .form-sub {
    color: var(--gray-600);
    margin-bottom: 24px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group label {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--gray-700);
  }

  .form-group input,
  .form-group textarea {
    padding: 12px 16px;
    border: 2px solid var(--gray-100);
    border-radius: 10px;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: var(--gray-800);
    transition: border-color 0.2s;
    background: var(--gray-50);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--ocean);
    background: white;
  }

  .form-group textarea { resize: vertical; }

  .btn {
    display: inline-block;
    padding: 14px 32px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1rem;
    transition: all 0.2s;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--ocean);
    color: white;
  }

  .btn-primary:hover {
    background: var(--deep);
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 32px; }
    .form-row { grid-template-columns: 1fr; }
  }

  /* Details */
  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .detail-card {
    background: var(--gray-50);
    border: 1px solid var(--gray-100);
    border-radius: 14px;
    padding: 20px;
  }

  .detail-icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 8px;
  }

  .detail-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 6px;
    color: var(--gray-900);
  }

  .detail-card p {
    font-size: 0.95rem;
    color: var(--gray-700);
    line-height: 1.5;
  }

  .detail-card a {
    color: var(--ocean);
    font-weight: 600;
  }

  .detail-note {
    font-size: 0.85rem !important;
    color: var(--gray-600) !important;
    margin-top: 4px;
  }

  /* Map */
  .map-section {
    padding: 0 0 64px;
    background: var(--white);
  }

  .map-section iframe {
    display: block;
    width: 100%;
  }
</style>